generator client {
  provider = "prisma-client-js"
}
 datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
 
// Eid Reunion Registration Table
model ReunionRegistration {
  id                    String   @id @default(cuid()) 
  fullName              String
  nickname              String?
  mobileNumber          String   @unique
  email                 String?
  batchPassingYear      String
  bloodGroup            String?
  
  currentProfession     String?
  currentLocation       String?
  tShirtSize            String   
  foodPreference        String   
  facebookLink          String?
  emergencyContact      String?
  additionalMessage     String?
  
  transactionId         String   @unique
  paymentScreenshotUrl  String?  
  uploadedPhotoUrl      String?  
  
  paymentStatus         String   @default("PENDING") 
  registrationDate      DateTime @default(now())
}

// Admin Panel User Table
model AdminUser {
  id       String @id @default(cuid())
  username String @unique
  password String 
  role     String @default("EXECUTIVE")
}

// Karjokori Committee Table (For Portal Login)
model CommitteeMember {
  id            String   @id @default(cuid())
  memberId      String   @unique  // Eita hobe tader login ID (e.g., MOC-26-01)
  password      String   // Login Password
  fullName      String
  designation   String   // e.g., President, Sports Secretary
  bloodGroup    String?
  mobileNumber  String
  email         String?
  profileImage  String?  // Chobir jonno
  role          String   @default("COMMITTEE") // Role (ADMIN ba COMMITTEE)
  createdAt     DateTime @default(now())
}
// General Club Membership Application Table
model ClubMemberApplication {
  id               String   @id @default(cuid())
  fullName         String
  mobileNumber     String   @unique
  bloodGroup       String
  presentAddress   String
  occupation       String?
  status           String   @default("PENDING") // PENDING, APPROVED, REJECTED
  applicationDate  DateTime @default(now())
}
 model Album {
  id          String   @id @default(cuid())
  title       String
  category    String
  coverImage  String?  // Ei album-er main ba cover chobi
  createdAt   DateTime @default(now())
  photos      Photo[]  // Ei album-er vitore thaka onnanno shob chobir list
}

model Photo {
  id          String   @id @default(cuid())
  imageUrl    String
  albumId     String
  album       Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}
// --- MOC Notice Board Model ---
model Notice {
  id          String   @id @default(cuid())
  title       String
  content     String
  isUrgent    Boolean  @default(false)
  authorName  String
  authorRole  String?
  createdAt   DateTime @default(now())
}

// --- MOC Super Chat Model ---
model Message {
  id          String   @id @default(cuid())
  content     String
  imageUrl    String?  // Attachment (Chobi/File) er jonno
  senderName  String
  senderRole  String?
  createdAt   DateTime @default(now())
}
// -----------------------------------------
// NEW MODELS FOR DYNAMIC CMS (PORTAL CONTROL)
// -----------------------------------------

// 1. Events & Tournaments
model Event {
  id          String   @id @default(cuid())
  title       String
  tag         String   // e.g., "Just Concluded", "Upcoming", "Signature Tradition"
  time        String   // e.g., "12:30 PM", "Dec / Jan"
  image       String   // URL from Cloudinary
  description String
  extraNote   String?  // Optional executive notice
  category    String   @default("upcoming") // e.g., "concluded", "upcoming", "winter", "tradition"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 2. Stats Board
model Stat {
  id          String   @id @default(cuid())
  title       String   // e.g., "Active Members"
  value       String   // e.g., "500+"
  icon        String   // e.g., "👥" ba icon nam
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 3. Social Initiatives (Mission Briefing)
model SocialInitiative {
  id          String   @id @default(cuid())
  title       String   // e.g., "Yearly Shikkhabritti"
  tagline     String   // e.g., "Empowering the Next Generation"
  description String
  image       String   // URL from Cloudinary
  icon        String   // e.g., "🎓"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

 // 4. Executive Committee (Renamed to avoid conflict)
model ExecutiveMember {
  id          String   @id @default(cuid())
  name        String
  role        String
  image       String?  // Optional (URL from Cloudinary)
  bio         String?
  phone       String?
  email       String?
  order       Int      @default(0) // Jate president ke shobar upore dekhano jay
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}// -----------------------------------------
// 🏆 SPORTS ANALYTICS & STATS BOARD MODELS
// -----------------------------------------

// 5. League Point Table (Football/Cricket)
model PointTable {
  id        String   @id @default(cuid())
  teamName  String
  played    Int      @default(0)
  won       Int      @default(0)
  drawn     Int      @default(0)
  lost      Int      @default(0)
  points    Int      @default(0)
  order     Int      @default(0) // Table e ke koto upore thakbe
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 6. Tactical Players (Ground/Court View)
 model TacticalPlayer {
  id        String   @id @default(cuid())
  sport     String   
  name      String   
  stats     String   
  tag       String?  
  image     String?  // 📸 Ei line ta notun add korbi
  slot      Int      @default(1) 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}